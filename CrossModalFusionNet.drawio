<mxfile host="app.diagrams.net" modified="2026-04-27" version="21.0.0">
  <diagram name="1. Model Evolution" id="diag_p1">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p1_title" value="CrossModalFusionNet — 5-Model Progressive Ablation" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="10" width="750" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p1_m1" value="&lt;b&gt;Model 1 — Random Forest on ELA&lt;/b&gt;&lt;br&gt;Streams: Hand-crafted ELA statistics (mean error, edge ratio, histogram bins)&lt;br&gt;Fusion: Feature table fed to RF classifier (100 trees, max_depth=10)&lt;br&gt;Limitation: Brittle under re-compression; no learned representation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="540" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="p1_m1" target="p1_m2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_l1" value="&lt;b&gt;+&lt;/b&gt; End-to-end CNN; replaces hand-crafted features with learned RGB representation" style="text;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="112" width="340" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1_m2" value="&lt;b&gt;Model 2 — Single-Stream EfficientNet-B0&lt;/b&gt;&lt;br&gt;Streams: RGB only (224×224 ImageNet-pretrained)&lt;br&gt;Fusion: Global average pool → Linear(1280 → 2)&lt;br&gt;Limitation: No forensic signal; RGB alone misses subtle artifacts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="540" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="p1_m2" target="p1_m3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_l2" value="&lt;b&gt;+&lt;/b&gt; Noise residual + DCT log-magnitude streams; sigmoid gate per channel" style="text;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="232" width="340" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1_m3" value="&lt;b&gt;Model 3 — 3-Stream CNN with Sigmoid Gating&lt;/b&gt;&lt;br&gt;Streams: RGB + Noise residual + DCT log-magnitude&lt;br&gt;Fusion: Concatenate 3840-dim → sigmoid gates → weighted sum&lt;br&gt;Limitation: Gate weights fixed per stream; no sample-adaptive reweighting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="540" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="p1_m3" target="p1_m4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_l3" value="&lt;b&gt;+&lt;/b&gt; Learnable softmax attention — stream weights adapt per image" style="text;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="352" width="340" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1_m4" value="&lt;b&gt;Model 4 — AdaptiveFusionNet&lt;/b&gt;&lt;br&gt;Streams: RGB + Noise residual + DCT log-magnitude&lt;br&gt;Fusion: Learnable softmax attention over concatenated 3840-dim features&lt;br&gt;Limitation: Streams weighted independently; no inter-modality interaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="540" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="p1_m4" target="p1_m5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_l4" value="&lt;b&gt;+&lt;/b&gt; ViT-B/16 global context stream (4th modality via CLS token)" style="text;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=10;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="472" width="340" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1_m5" value="&lt;b&gt;Model 5 — ViTMultiModalFusionNet&lt;/b&gt;&lt;br&gt;Streams: RGB + Noise + DCT + ViT-B/16 (CLS token, projected 768→1280)&lt;br&gt;Fusion: Sample-adaptive softmax attention over 4 stream features&lt;br&gt;Limitation: Still scalar attention; streams don&apos;t interact during fusion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="540" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" source="p1_m5" target="p1_m6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_l5" value="&lt;b&gt;★ Novel A:&lt;/b&gt; ELA as 5th learned CNN stream&lt;br&gt;&lt;b&gt;★ Novel B:&lt;/b&gt; Cross-Modal Transformer Encoder — modalities attend to each other" style="text;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=10;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="582" width="340" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p1_m6" value="&lt;b&gt;★ CrossModalFusionNet — PRIMARY CONTRIBUTION&lt;/b&gt;&lt;br&gt;Streams: RGB + ELA (★ novel CNN stream) + Noise + DCT + ViT (5 streams)&lt;br&gt;Fusion: ★ Modality Transformer Encoder (2L, 8H, d=1280) — cross-modal self-attention&lt;br&gt;Novel A: ELA end-to-end in CNN backbone | Novel B: Inter-modality transformer fusion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;align=left;spacingLeft=8;spacingTop=4;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="80" y="660" width="540" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="p1_leg_title" value="Color Key" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="790" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p1_leg1" value="Classical baseline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="815" width="150" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="p1_leg2" value="Deep learning model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="245" y="815" width="150" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="p1_leg3" value="★ Novel contribution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="410" y="815" width="150" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="p1_leg4" value="What was added at this step" style="text;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="575" y="815" width="200" height="25" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
